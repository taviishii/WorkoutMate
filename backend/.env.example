# Server Configuration
PORT=6060
CLIENT_URL=http://localhost:3000
ORIGIN=http://localhost:3000

# MongoDB Connection
MONGO_URI=mongodb://localhost:27017/workoutmate

# JWT Secret & Bcrypt Salt (replace with your own secret in production!)
SECRET=your-secret-key-here
SALT=10

# Email (Optional – for password reset & account verification)
# Use Ethereal Email for testing: https://ethereal.email/
EMAIL_HOST=smtp.ethereal.email
EMAIL_USERNAME=
EMAIL_PASSWORD=
# Or use Gmail with an app password:
# EMAIL_SERVICE=gmail
# EMAIL_USERNAME=your-email@gmail.com
# EMAIL_PASSWORD=your-gmail-app-password

# Optional Limits
MAX_USERS=1000
MAX_WORKOUTS_PER_USER=1000
